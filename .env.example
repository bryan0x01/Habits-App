# DayFlow environment variables
#
# The MVP runs entirely on localStorage and needs NO environment variables —
# you can deploy to Vercel with none of these set. They're placeholders for the
# planned backend so the wiring is obvious when you add it.
#
# Copy this file to `.env.local` and fill in values when you enable Supabase:
#
#   cp .env.example .env.local

# --- Supabase (future: cross-device sync + auth) ---------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Web Push (future: real block reminders) -------------------------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
